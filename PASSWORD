import string

def check_password_strength(password):
    """
    Checks the strength of a given password and returns a score with feedback.
    """
    score = 0
    feedback = []

    # Length check
    if len(password) >= 12:
        score += 2
    elif len(password) >= 8:
        score += 1
    else:
        feedback.append("Password is too short (min 8 characters).")

    # Uppercase check
    if any(ch.isupper() for ch in password):
        score += 1
    else:
        feedback.append("Add at least one uppercase letter.")

    # Lowercase check
    if any(ch.islower() for ch in password):
        score += 1
    else:
        feedback.append("Add at least one lowercase letter.")

    # Digit check
    if any(ch.isdigit() for ch in password):
        score += 1
    else:
        feedback.append("Add at least one digit.")

    # Special character check
    if any(ch in string.punctuation for ch in password):
        score += 1
    else:
        feedback.append("Add at least one special character (!@#$ etc.).")

    return score, feedback


def main():
    password = input("Enter your password: ").strip()

    # Input validation
    if not password:
        print("Password cannot be empty.")
        return

    score, feedback = check_password_strength(password)

    print(f"\nPassword Strength Score: {score}/6")
    if score == 6:
        print("✅ Strong password!")
    elif score >= 4:
        print("⚠️ Medium strength password. Consider improving it.")
    else:
        print("❌ Weak password. Please improve it.")

    if feedback:
        print("\nSuggestions:")
        for tip in feedback:
            print(f"- {tip}")


if __name__ == "__main__":
    main()
