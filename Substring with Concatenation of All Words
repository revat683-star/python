from collections import Counter

class Solution:
    def findSubstring(self, s: str, words: List[str]) -> List[int]:
        if not s or not words: return []
        
        word_len = len(words[0])
        word_count = len(words)
        total_len = word_len * word_count
        counts = Counter(words)
        res = []
        
        # We only need to check offsets up to word_len
        for i in range(word_len):
            left = i
            right = i
            current_seen = Counter()
            count = 0
            
            # Slide the window across the string
            while right + word_len <= len(s):
                word = s[right : right + word_len]
                right += word_len
                
                if word in counts:
                    current_seen[word] += 1
                    count += 1
                    # If we have too many of one word, shift left
                    while current_seen[word] > counts[word]:
                        left_word = s[left : left + word_len]
                        current_seen[left_word] -= 1
                        count -= 1
                        left += word_len
                    
                    # If all words match
                    if count == word_count:
                        res.append(left)
                else:
                    # Reset if word is not valid
                    current_seen.clear()
                    count = 0
                    left = right
                    
        return res
