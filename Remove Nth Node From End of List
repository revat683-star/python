class Solution:
    def removeNthFromEnd(self, head: Optional[ListNode], n: int) -> Optional[ListNode]:
        dummy = ListNode(0, head)
        left = dummy
        right = head
        
        # Advance right pointer by n steps
        while n > 0 and right:
            right = right.next
            n -= 1
            
        # Move both until right reaches the end
        while right:
            left = left.next
            right = right.next
            
        # Delete the node
        left.next = left.next.next
        
        return dummy.next
