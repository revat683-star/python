class Solution:
    def insert(self, intervals: list[list[int]], newInterval: list[list[int]]) -> list[list[int]]:
        res = []
        i = 0
        n = len(intervals)
        
        # 1. Add all intervals that come before the newInterval
        while i < n and intervals[i][1] < newInterval[0]:
            res.append(intervals[i])
            i += 1
            
        # 2. Merge all overlapping intervals with the newInterval
        while i < n and intervals[i][0] <= newInterval[1]:
            newInterval[0] = min(newInterval[0], intervals[i][0])
            newInterval[1] = max(newInterval[1], intervals[i][1])
            i += 1
        
        # Add the merged newInterval
        res.append(newInterval)
        
        # 3. Add the remaining intervals
        while i < n:
            res.append(intervals[i])
            i += 1
            
        return res
