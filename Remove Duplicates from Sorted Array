class Solution:
    def removeDuplicates(self, nums: List[int]) -> int:
        if not nums:
            return 0
        
        # L is the index of the last known unique element
        l = 0
        
        # R scans the array starting from the second element
        for r in range(1, len(nums)):
            if nums[r] != nums[l]:
                l += 1
                nums[l] = nums[r]
                
        return l + 1
