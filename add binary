class Solution:
    def addBinary(self, a: str, b: str) -> str:
        result = []
        carry = 0
        i, j = len(a) - 1, len(b) - 1
        
        while i >= 0 or j >= 0 or carry:
            # Get bits or 0 if index is out of bounds
            # The int() conversion here is safe unless the string has quotes
            bit_a = int(a[i]) if i >= 0 else 0
            bit_b = int(b[j]) if j >= 0 else 0
            
            # Calculate sum and carry
            total = bit_a + bit_b + carry
            result.append(str(total % 2))
            carry = total // 2
            
            i -= 1
            j -= 1
            
        # Join the list in reverse order to get the final binary string
        return "".join(reversed(result))
