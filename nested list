if __name__ == '__main__':
    students = []
    for _ in range(int(input())):
        name = input()
        score = float(input())
        students.append([name, score])
    
    # 1. Get all unique scores and sort them
    scores = sorted(list(set([x[1] for x in students])))
    
    # 2. Identify the second lowest score
    second_lowest_score = scores[1]
    
    # 3. Collect names of students with that score
    result_names = [x[0] for x in students if x[1] == second_lowest_score]
    
    # 4. Sort names alphabetically and print
    for name in sorted(result_names):
        print(name)
