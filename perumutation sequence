import math

class Solution:
    def getPermutation(self, n: int, k: int) -> str:
        # Create a list of numbers to pick from: [1, 2, 3, ..., n]
        numbers = [i for i in range(1, n + 1)]
        
        # Precompute factorials for efficiency
        # We need (n-1)! for each step
        factorial = math.factorial(n - 1)
        
        # Adjust k to be 0-indexed for easier math
        k -= 1
        result = []
        
        for i in range(n - 1, 0, -1):
            # Determine the index of the number to pick
            idx = k // factorial
            
            # Add the selected number to our result and remove it from the list
            result.append(str(numbers.pop(idx)))
            
            # Update k and the factorial for the next position
            k %= factorial
            factorial //= i
            
        # Append the final remaining number
        result.append(str(numbers[0]))
        
        return "".join(result)
