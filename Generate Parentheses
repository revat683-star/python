class Solution:
    def generateParenthesis(self, n: int) -> List[str]:
        res = []
        
        def backtrack(open_count, closed_count, current_s):
            # Base case: valid combination found
            if len(current_s) == 2 * n:
                res.append(current_s)
                return
            
            # Rule 1: Add an opening bracket if we have more to use
            if open_count < n:
                backtrack(open_count + 1, closed_count, current_s + "(")
            
            # Rule 2: Add a closing bracket if it won't break the order
            if closed_count < open_count:
                backtrack(open_count, closed_count + 1, current_s + ")")
        
        backtrack(0, 0, "")
        return res
