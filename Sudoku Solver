class Solution:
    def solveSudoku(self, board: List[List[str]]) -> None:
        """
        Do not return anything, modify board in-place instead.
        """
        self.solve(board)

    def solve(self, board):
        for r in range(9):
            for c in range(9):
                if board[r][c] == ".":
                    for char in "123456789":
                        if self.isValid(board, r, c, char):
                            board[r][c] = char
                            # Recursively try to solve the rest of the board
                            if self.solve(board):
                                return True
                            # Backtrack
                            board[r][c] = "."
                    return False
        return True

    def isValid(self, board, r, c, char):
        for i in range(9):
            # Check row
            if board[r][i] == char: return False
            # Check column
            if board[i][c] == char: return False
            # Check 3x3 square
            # (r // 3 * 3) and (c // 3 * 3) give the top-left corner of the box
            if board[3 * (r // 3) + i // 3][3 * (c // 3) + i % 3] == char:
                return False
        return True
