class Solution:
    def maxArea(self, height: list[int]) -> int:
        left = 0
        right = len(height) - 1
        max_water = 0
        
        while left < right:
            # Calculate current width
            width = right - left
            
            # Calculate current area using the shorter wall
            current_height = min(height[left], height[right])
            current_area = width * current_height
            
            # Update max_water if the current one is larger
            max_water = max(max_water, current_area)
            
            # Strategy: Move the pointer that is shorter
            if height[left] < height[right]:
                left += 1
            else:
                right -= 1
                
        return max_water
