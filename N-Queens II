class Solution:
    def totalNQueens(self, n: int) -> int:
        # Sets to track occupied paths
        cols = set()
        posDiag = set() # (r + c)
        negDiag = set() # (r - c)
        
        self.count = 0
        
        def backtrack(r):
            # Base Case: If we've reached the last row, we found a solution
            if r == n:
                self.count += 1
                return
            
            for c in range(n):
                # If the current square is under attack, skip it
                if c in cols or (r + c) in posDiag or (r - c) in negDiag:
                    continue
                
                # Place the queen (add to sets)
                cols.add(c)
                posDiag.add(r + c)
                negDiag.add(r - c)
                
                # Recursively move to the next row
                backtrack(r + 1)
                
                # Backtrack: Remove the queen (remove from sets)
                cols.remove(c)
                posDiag.remove(r + c)
                negDiag.remove(r - c)
                
        backtrack(0)
        return self.count
